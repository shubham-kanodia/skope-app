# Supabase Postgres — transaction pooler (port 6543). Driver uses prepare:false.
# Never commit the real value; this file holds placeholders only.
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-1-us-west-1.pooler.supabase.com:6543/postgres"

# Auth — secret used to sign magic-link tokens and session cookies (32+ random bytes, base64/hex).
AUTH_SECRET="generate-with: openssl rand -base64 48"

# Field-level encryption master key (AES-256-GCM). 32 bytes, base64. [M1]
ENCRYPTION_MASTER_KEY="generate-with: openssl rand -base64 32"

# Transactional email goes through Maileroo (see MAILEROO_SENDING_KEY below).
# EMAIL_FROM is the verified sender as "Display Name <addr@your-domain>".
EMAIL_FROM="Skope <login@skope.network>"

# Upstash Redis (REST) — rate limiting. Falls back to in-memory when unset (dev only).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Google Cloud Translation API key — auto-translates banner copy into Indian languages.
GOOGLE_TRANSLATE_API_KEY=""

# OpenRouter — drafts DPDP privacy notices (OpenAI-compatible API). When unset,
# the generator falls back to a deterministic template, so dev/CI never call out.
OPENROUTER_API_KEY=""
# Model slug. Defaults to google/gemini-2.5-flash when blank.
OPENROUTER_MODEL=""

# Public base URLs.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_CDN_URL="http://localhost:3000"

# Razorpay — plan checkout + webhook. Checkout is stub-safe when blank (owners
# can grant a plan manually). RAZORPAY_WEBHOOK_SECRET verifies webhook signatures.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Shared secret for the usage-dunning cron (POST /api/cron/usage-sweep). Disabled when blank.
CRON_SECRET=""

# Dev/E2E only. "true" lets the single test account (skope-test-email123@skope.network)
# sign in without the magic-link email. This is an auth bypass: leave it blank in
# production. Off by default.
ALLOW_TEST_LOGIN=""

# Maileroo Sending Key (from your verified Maileroo domain). Falls back to console logging when unset.
MAILEROO_SENDING_KEY=""

# Google Analytics 4 measurement ID (G-...). Nothing loads and events no-op when
# blank, so local dev stays out of production stats. Inlined at build time —
# set it in the deploy platform's env, not just at runtime.
NEXT_PUBLIC_GA_ID=""
